				<key>script</key>
				<string>// Helpers
function envVar(varName) {
  return $.NSProcessInfo
    .processInfo
    .environment
    .objectForKey(varName).js
}

function developMenuOn() {
  const task = $.NSTask.alloc.init
  const stdout = $.NSPipe.pipe

  task.executableURL = $.NSURL.alloc.initFileURLWithPath("/usr/bin/defaults")
  task.arguments = ["read", "com.apple.Safari", "IncludeDevelopMenu"]
  task.standardOutput = stdout
  task.launchAndReturnError(false)

  const dataOut = stdout.fileHandleForReading.readDataToEndOfFile
  const stringOut = $.NSString.alloc.initWithDataEncoding(dataOut, $.NSUTF8StringEncoding).js

  return stringOut.trim() === "1"
}

// Main
function run(argv) {
  // Menu breadcrumbs
  const breadcrumbs = envVar("user_agent_menu").split("\n")

  // Checks
  if (!developMenuOn()) {
    return JSON.stringify({ items: [{
      title: "Safari’s Develop Menu Is Not Active",
      subtitle: "It Is Required to Change User Agent",
      valid: false
    }]})
  }

  // Grab user agents
  const browserAgents = Application("System Events")
    .processes
    .byName("Safari")
    .menuBars[0]
    .menuBarItems
    .byName(breadcrumbs[0])
    .menus[0]
    .menuItems
    .byName(breadcrumbs[1])
    .menus[0]
    .menuItems()
    .map(item =&gt; item.name())
    .filter(item =&gt; item !== null)

  // Build Items
  const sfItems = browserAgents.map(agent =&gt; ({ title: agent, arg: agent }))
  return JSON.stringify({ cache: { seconds: 86400, loosereload: true }, items: sfItems })
}</string>
