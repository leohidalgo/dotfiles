				<string>function envVar(varName) {
  return $.NSProcessInfo
    .processInfo
    .environment
    .objectForKey(varName).js
}

function urlComponents(url, componentsCount) {
  const host = url.scheme.js + "://" + url.host.js + "/"
  const components = url.pathComponents.js.map(a =&gt; encodeURIComponent(a.js)).slice(1)

  return host + components.slice(0, componentsCount).join("/")
}

function run(argv) {
  const url = $.NSURL.URLWithString(argv[0])

  if (envVar("smart_domain") === "0") return urlComponents(url, 0) 

  switch (url.host.js.replace(/^www\d*\./, "")) {
    case "github.com": return urlComponents(url, 2)
    default: return urlComponents(url, 0)
  }
}</string>
