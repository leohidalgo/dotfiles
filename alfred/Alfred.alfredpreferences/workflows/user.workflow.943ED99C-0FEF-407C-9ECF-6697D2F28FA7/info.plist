				<string>readonly wf_cache="${alfred_workflow_cache}/icons"
readonly ti_cache="${HOME}/Library/Safari/Touch Icons Cache"

/bin/mkdir -p "${wf_cache}"

while IFS= read -r host
do
  [[ -f "${wf_cache}/${host}.png" ]] &amp;&amp; continue
  /bin/cp "${ti_cache}/images/$(echo -n "${host}" | /sbin/md5 | /usr/bin/tr '[:lower:]' '[:upper:]').png" "${wf_cache}/${host}.png"
done &lt; &lt;(/usr/bin/sqlite3 "${ti_cache}/TouchIconCacheSettings.db" 'SELECT host FROM cache_settings WHERE icon_is_in_cache')</string>
